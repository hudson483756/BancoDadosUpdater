<Window x:Class="BancoDadosUpdater.Views.DataViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visualizador de Dados" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Selecione a Tabela: " VerticalAlignment="Center" FontWeight="Bold"/>
            <ComboBox x:Name="CmbTabelas" Width="200" Margin="10,0,0,0" 
                      SelectionChanged="CmbTabelas_SelectionChanged" DisplayMemberPath="TableName"/>
        </StackPanel>

        <DataGrid x:Name="GridDados" Grid.Row="1" AutoGenerateColumns="True" 
                  IsReadOnly="True" AlternatingRowBackground="#FFF0F0F0" 
                  CanUserAddRows="False" CanUserDeleteRows="False"/>
    </Grid>
</Window>